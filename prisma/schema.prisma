generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  subscriptionPlan  SubscriptionPlan @default(FREE)
  subscriptionExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes   Recipe[] @relation("RecipeCreator")
  favorites Favorite[]
  reviews   Review[]
  subscriptions Subscription[]
  paymentTransactions PaymentTransaction[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipes     Recipe[]
}

model Recipe {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  description     String    @db.Text
  ingredients     String    @db.LongText
  instructions    String    @db.LongText
  imageUrl        String?
  prepTimeMinutes Int?
  cookTimeMinutes Int?
  difficulty      String?   @db.VarChar(50)
  servings        Int?
  averageRating   Float     @default(0)
  ratingCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  categoryId      Int
  createdById     Int

  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy       User      @relation("RecipeCreator", fields: [createdById], references: [id], onDelete: Restrict)
  favorites       Favorite[]
  reviews         Review[]

  @@index([categoryId])
  @@index([createdById])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  recipeId  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?  @db.Text
  userId    Int
  recipeId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
}

model Subscription {
  id        Int                @id @default(autoincrement())
  userId    Int
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(PENDING)
  amount    Int
  periodDays Int               @default(30)
  currency  String             @default("IDR") @db.VarChar(10)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction?

  @@index([userId, status])
  @@index([expiresAt])
}

model PaymentTransaction {
  id             Int            @id @default(autoincrement())
  orderId        String         @unique @db.VarChar(191)
  subscriptionId Int            @unique
  userId         Int
  provider       String         @default("SIMULATED_MIDTRANS") @db.VarChar(50)
  status         PaymentStatus  @default(PENDING)
  paymentToken   String         @unique @db.VarChar(191)
  paymentUrl     String?        @db.VarChar(255)
  grossAmount    Int
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
